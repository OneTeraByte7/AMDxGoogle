# ==========================================
# Food & Health App — Server Environment
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# Firebase Admin SDK
# Paste your service account JSON as a single-line string (use JSON.stringify)
# Or set the path to the service account file:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Edamam Nutrition API (https://developer.edamam.com/)
# Leave empty to use mock data fallback
EDAMAM_APP_ID=your_edamam_app_id
EDAMAM_APP_KEY=your_edamam_app_key
EDAMAM_BASE_URL=https://api.edamam.com

# Google Maps / Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# CORS — Frontend origin
CLIENT_ORIGIN=http://localhost:5173
