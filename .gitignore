.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local

# ── Firebase service account keys ────────────────────────────────────────────
serviceAccount.json
*serviceAccount*.json
firebase-adminsdk*.json

# ── Build outputs ─────────────────────────────────────────────────────────────
client/dist/
client/build/
server/dist/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Testing & coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE & editor ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Vite cache ────────────────────────────────────────────────────────────────
client/.vite/

